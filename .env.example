NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dev-only — utilisé par /api/dev/login pour automatiser Playwright.
# Le endpoint refuse en NODE_ENV=production. NE JAMAIS pousser de vraies
# credentials prod ici.
TEST_USER_EMAIL=test@divarc.app
TEST_USER_PASSWORD=changeme

# === DIVARC Ads — Creative Studio (étape 9) ===
# Stock photos (Pexels gratuit, inscription : https://www.pexels.com/api/)
PEXELS_API_KEY=
# Stock photos (Unsplash gratuit, inscription : https://unsplash.com/developers)
UNSPLASH_ACCESS_KEY=
# Génération IA d'images via Replicate Stable Diffusion XL
# (https://replicate.com/account/api-tokens) — ~$0.005 / image
REPLICATE_API_TOKEN=

# === DIVARC Ads — Keyword Planner (étape 11) ===
# DataForSEO Keywords Data API (https://app.dataforseo.com/api-access)
# Compte Sandbox gratuit ~ $1 — V1 mutualise le cache 90j entre comptes.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# === DIVARC Posts — Localisation (Phase 1.5) ===
# Mapbox Places API pour le picker de lieu dans le composer.
# (https://account.mapbox.com/) — gratuit jusqu'à 100k requêtes/mois.
MAPBOX_ACCESS_TOKEN=

# === DIVARC Posts — Programmation (Phase 1.9) ===
# Secret Bearer pour authentifier les crons Vercel.
# (https://vercel.com/docs/cron-jobs#manage-cron-jobs)
# Configuré automatiquement quand tu actives Vercel Cron.
CRON_SECRET=
